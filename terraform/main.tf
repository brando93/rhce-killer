terraform {
  required_version = ">= 1.5"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# ─────────────────────────────────────────────
# SSH Key Pair (generated by Terraform)
# ─────────────────────────────────────────────

resource "tls_private_key" "rhce" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "rhce" {
  key_name   = "${var.project_name}-key"
  public_key = tls_private_key.rhce.public_key_openssh
}

resource "local_file" "private_key" {
  content         = tls_private_key.rhce.private_key_pem
  filename        = "${path.module}/../${var.project_name}.pem"
  file_permission = "0600"
}

# ─────────────────────────────────────────────
# VPC & Networking
# ─────────────────────────────────────────────

resource "aws_vpc" "rhce" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_support   = true
  enable_dns_hostnames = true
  tags = { Name = "${var.project_name}-vpc" }
}

resource "aws_internet_gateway" "rhce" {
  vpc_id = aws_vpc.rhce.id
  tags   = { Name = "${var.project_name}-igw" }
}

# Public Subnet - for control node with direct internet access
resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.rhce.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = "${var.aws_region}a"
  map_public_ip_on_launch = true
  tags                    = { Name = "${var.project_name}-public-subnet" }
}

# Private Subnet - for managed nodes with NAT Gateway access
resource "aws_subnet" "private" {
  vpc_id                  = aws_vpc.rhce.id
  cidr_block              = "10.0.2.0/24"
  availability_zone       = "${var.aws_region}a"
  map_public_ip_on_launch = false
  tags                    = { Name = "${var.project_name}-private-subnet" }
}

# Elastic IP for NAT Gateway
resource "aws_eip" "nat" {
  domain = "vpc"
  tags   = { Name = "${var.project_name}-nat-eip" }
}

# NAT Gateway in public subnet for managed nodes to access internet
resource "aws_nat_gateway" "rhce" {
  allocation_id = aws_eip.nat.id
  subnet_id     = aws_subnet.public.id
  tags          = { Name = "${var.project_name}-nat" }
  
  depends_on = [aws_internet_gateway.rhce]
}

# Public Route Table - for control node (direct internet via IGW)
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.rhce.id
  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.rhce.id
  }
  tags = { Name = "${var.project_name}-public-rt" }
}

# Private Route Table - for managed nodes (internet via NAT Gateway)
resource "aws_route_table" "private" {
  vpc_id = aws_vpc.rhce.id
  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.rhce.id
  }
  tags = { Name = "${var.project_name}-private-rt" }
}

resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

resource "aws_route_table_association" "private" {
  subnet_id      = aws_subnet.private.id
  route_table_id = aws_route_table.private.id
}

# ─────────────────────────────────────────────
# Security Groups
# ─────────────────────────────────────────────

resource "aws_security_group" "control" {
  name        = "${var.project_name}-control-sg"
  description = "Control node: SSH from your IP only"
  vpc_id      = aws_vpc.rhce.id

  ingress {
    description = "SSH from your machine"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.my_ip]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${var.project_name}-control-sg" }
}

resource "aws_security_group" "nodes" {
  name        = "${var.project_name}-nodes-sg"
  description = "Managed nodes: SSH from control node only"
  vpc_id      = aws_vpc.rhce.id

  ingress {
    description     = "SSH from control node"
    from_port       = 22
    to_port         = 22
    protocol        = "tcp"
    security_groups = [aws_security_group.control.id]
  }

  ingress {
    description     = "All traffic from control node (Ansible)"
    from_port       = 0
    to_port         = 0
    protocol        = "-1"
    security_groups = [aws_security_group.control.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${var.project_name}-nodes-sg" }
}

# ─────────────────────────────────────────────
# AMI: Rocky Linux 9 (official marketplace)
# ─────────────────────────────────────────────

data "aws_ami" "rocky9" {
  most_recent = true
  owners      = ["792107900819"] # Rocky Linux official AWS account

  filter {
    name   = "name"
    values = ["Rocky-9-EC2-Base-9.*x86_64*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }
}

# ─────────────────────────────────────────────
# EC2 Instances
# ─────────────────────────────────────────────

resource "aws_instance" "control" {
  ami                         = data.aws_ami.rocky9.id
  instance_type               = var.control_instance_type
  subnet_id                   = aws_subnet.public.id
  vpc_security_group_ids      = [aws_security_group.control.id]
  key_name                    = aws_key_pair.rhce.key_name
  associate_public_ip_address = true
  private_ip                  = "10.0.1.10"

  root_block_device {
    volume_size = 20
    volume_type = "gp3"
  }

  user_data = templatefile("${path.module}/user_data/control.sh", {
    node1_ip    = "10.0.2.11"
    node2_ip    = "10.0.2.12"
    private_key = tls_private_key.rhce.private_key_pem
  })

  tags = { Name = "control.example.com", Role = "control" }
}

resource "aws_instance" "node1" {
  ami                         = data.aws_ami.rocky9.id
  instance_type               = var.node_instance_type
  subnet_id                   = aws_subnet.private.id
  vpc_security_group_ids      = [aws_security_group.nodes.id]
  key_name                    = aws_key_pair.rhce.key_name
  associate_public_ip_address = false
  private_ip                  = "10.0.2.11"

  root_block_device {
    volume_size = 10
    volume_type = "gp3"
  }

  user_data = templatefile("${path.module}/user_data/node.sh", {
    public_key = tls_private_key.rhce.public_key_openssh
  })

  tags = { Name = "node1.example.com", Role = "node" }
}

resource "aws_instance" "node2" {
  ami                         = data.aws_ami.rocky9.id
  instance_type               = var.node_instance_type
  subnet_id                   = aws_subnet.private.id
  vpc_security_group_ids      = [aws_security_group.nodes.id]
  key_name                    = aws_key_pair.rhce.key_name
  associate_public_ip_address = false
  private_ip                  = "10.0.2.12"

  root_block_device {
    volume_size = 10
    volume_type = "gp3"
  }

  user_data = templatefile("${path.module}/user_data/node.sh", {
    public_key = tls_private_key.rhce.public_key_openssh
  })

  tags = { Name = "node2.example.com", Role = "node" }
}
